{
  "build": {
    "beforeDevCommand": "node ./apps/tauri/scripts/sync-ios-composer-icon.mjs && pnpm --filter frontend dev:tauri",
    "beforeBuildCommand": "node ./apps/tauri/scripts/sync-ios-composer-icon.mjs && pnpm --filter frontend build:tauri",
    "frontendDist": "../../dist",
    "devUrl": "http://localhost:1420"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/ios/AppIcon-512@2x.png",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "copyright": "2026 Panorama Contributors",
    "category": "Finance",
    "createUpdaterArtifacts": "v1Compatible",
    "iOS": {
      "developmentTeam": "DYDJ2RNL5H",
      "infoPlist": "Info.ios.plist"
    }
  },
  "productName": "Panorama",
  "mainBinaryName": "Panorama",
  "version": "3.0.4",
  "identifier": "com.gallantguo.panorama",
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE5RDg2NERCQzY2MjFDNkQKUldSdEhHTEcyMlRZcVd1djNMdTBZZE9rYy9qdU9KQzhzU00zYzhmYTZzVHdwcG9RSHN4R1hDUUQK",
      "endpoints": ["https://github.com/galza-guo/Panorama/releases/latest/download/latest.json"],
      "windows": {
        "installMode": "passive"
      }
    },
    "deep-link": {
      "mobile": [
        { "host": "connect.wealthfolio.app", "pathPrefix": ["/deeplink"] },
        { "host": "connect-staging.wealthfolio.app", "pathPrefix": ["/deeplink"] }
      ],
      "desktop": {
        "schemes": ["wealthfolio"]
      },
      "schemes": ["wealthfolio"]
    }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "dragDropEnabled": false,
        "fullscreen": false,
        "resizable": true,
        "theme": "Light",
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "title": "Panorama",
        "width": 1440,
        "height": 960,
        "center": true
      }
    ],
    "security": {
      "csp": null
